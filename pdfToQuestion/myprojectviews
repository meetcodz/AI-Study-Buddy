import json
import requests
import re
from django.shortcuts import render
from .models import Question
def generate_questions(text, user_prompt=""):
    prompt = f"""
You are an expert teacher.
TASK:
Generate HIGH-QUALITY MCQs from the given text.Generate 20 MCQ's from the whole text.
IMPORTANT RULES:
- Questions must be concept-based (not random)
- Cover important topics from text
- Avoid repetition
- Make correct answers accurate
- For maths: include numerical/problem-solving questions
- For theory: include conceptual understanding
- For languages: include grammar, meaning, comprehension

STRICT FORMAT ONLY:
Q: question text
A) option
B) option
C) option
D) option
Answer: A/B/C/D

USER EXTRA INSTRUCTION:
{user_prompt}

TEXT:
{text}
"""
    response = requests.post(
        "http://localhost:11434/api/generate",
        json={
            "model": "mistral",
            "prompt": prompt,
            "stream": False
        }
    )
    return response.json().get("response", "")


