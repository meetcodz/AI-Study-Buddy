<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudyFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600&display=swap" rel="stylesheet">
    <style>
    .top-nav{
    position: fixed;
    top: 10px;
    right: 20px;
    display: flex;
     gap: 20px;
    }
    .nav{
        display : flex;
        gap: 25px;
        align-items: center;
    }header{
        backdrop-filter: blur(7px);
        background: rgba(10,12,18,0.01);
     position: fixed;
     top: 0;
     left: 0;
     width: 100%;
     height: 60px;
     box-sizing: border-box;

    display: flex;
    justify-content: space-between;
    align-items: center;

    padding: 0 30px;
    border-bottom: 1px solid #1A2535;

    z-index: 1000; 
    }
    .nav div{
     cursor: pointer;
     font-size: 14px;
     padding: 6px 12px;
    border-radius: 8px;
     transition:all 0.3s ease ;
    }

    .nav div:hover{
    color:#3B82F6;
    }
    body{
      margin:0;
      font-family:'Outfit',sans-serif;
      background:#0A0C12;
      color:#F0F2F5;
    }
    section{
      padding:60px;
      border-bottom:1px solid #1A2535;
      transition:all 0.3s ease;
      margin:20 px;
    }
    .logo
    {
        font-size:18px;
        font-weight=600;
    }
    section:hover
    {
        transform: scale(1.02);
        background:rgba(59, 121, 246, 0.05);
        box-shadow:0 0 20px rgba(59, 212, 246, 0.2);
        border-top:1px solid #3B82F6;
        border-bottom:1px solid #3B82F6;
    }

    h1,h2{
      margin-bottom:10px;
    }

    p{
      color:#4B5563;
    }
    .blue{color:#3B82F6;}
    .green{color:#14B8A6;}
    .yellow{color:#F59E0B;}
    </style>
</head>
<body>
    <header>
  <div class="logo blue">StudyFlow</div>

  <div class="nav">
    <div>Home</div>
    <div>Questions</div>
    <div>Quiz</div>
    <div>Profile</div>
   </div>
 </header>
    
    <section>
        <h1 class="blue">Dashboard</h1>
        <p>Basic UI for dashboard will be added here</p>
    </section>

    <section>
        <h1 class="blue">Daily Goal</h1>
        <p> Daily Goals based on Question will be put here</p>
    </section>

    <section>
        <h1 class="blue">Timer Pomodoro</h1>
        <p>Pomodoro Based Student Timer</p>
    </section>

    <section>
        <h1 class="blue">Heatmap</h1>
        <p> Heatmap of the user will be shown</p>
    </section>
</body>
</html>
